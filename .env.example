# Credentials API RTE (à obtenir sur https://data.rte-france.com)
RTE_CLIENT_ID=your_client_id_here
RTE_CLIENT_SECRET=your_client_secret_here

# Localisation du parc solaire (coordonnées GPS)
SOLAR_PARK_LAT=43.6115
SOLAR_PARK_LON=3.8772

# Région cible pour l'agrégation
SOLAR_REGION=Occitanie

# Irradiance à l'échelle nationale
USE_NATIONAL_IRRADIANCE=true
IRRADIANCE_GRID_RESOLUTION=1.0

# Répertoire de sortie
OUTPUT_DIR=output
